# Supabase (obtain from https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chiffrement credentials utilisateur (racine envelope encryption)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_MASTER_KEY=

# Email transactionnel pour emails système (reset password, notifications)
RESEND_API_KEY=

# IA fallback (optionnel - l'utilisateur peut aussi configurer sa propre clé)
MISTRAL_API_KEY=

# Rate limiting (optionnel pour dev local)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron security (Bearer token pour /api/cron/*)
CRON_SECRET=

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=marcbuffry@gmail.com
